                        </td>
                        <td class="p-4">
                            <div class="font-bold ${student.score < 60 ? 'text-red-500' : (student.score < 75 ? 'text-lesha-orange' : 'text-lesha-green')}">
                                ${student.score}%
                            </div>
                        </td>
                        <td class="p-4">
                            <span class="${student.weakCount > 5 ? 'text-red-500 font-bold' : 'text-slate-500'}">${student.weakCount}</span>
                        </td>
                        <td class="p-4 text-slate-500 text-xs">${student.lastActive}</td>
                        <td class="p-4">
                            <span class="px-2 py-1 rounded-full text-xs font-semibold ${this.getBadgeColor(student.status)}">
                                ${student.status}
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <i class="fa-solid fa-chevron-right text-slate-300"></i>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            },

            search(query) {
                const lowerQuery = query.toLowerCase();
                const filtered = students.filter(s =>
                    s.name.toLowerCase().includes(lowerQuery) ||
                    s.status.toLowerCase().includes(lowerQuery)
                );
                this.currentData = filtered;
                this.render(filtered);
            },

            sort(key) {
                // Simple toggle sort logic
                this.currentData.sort((a, b) => {
                   if (key === 'name') return a.name.localeCompare(b.name);
                   return b[key] - a[key]; // Descending for numbers
                });
                this.render(this.currentData);
            }
        };

        // --- Initialization ---
        document.addEventListener('DOMContentLoaded', () => {
            // Setup Search Listener
            document.getElementById('studentSearch').addEventListener('input', (e) => {
                tableManager.search(e.target.value);
            });

            // Start at dashboard
            router.navigateTo('dashboard');
