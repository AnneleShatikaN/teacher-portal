        // --- Logic Class: View Router ---
        const router = {
            views: ['dashboard', 'class', 'student'],

            navigateTo(viewId) {
                // Hide all views
                this.views.forEach(v => {
                    document.getElementById(`view-${v}`).classList.add('hidden-view');
                });

                // Show requested view
                const activeView = document.getElementById(`view-${viewId}`);
                activeView.classList.remove('hidden-view');

                // Scroll to top
                window.scrollTo(0, 0);

                // Specific initializers
                if(viewId === 'class') {
                    tableManager.render(students);
                }
            }
        };

        // --- Logic Class: Table Manager ---
        const tableManager = {
            currentData: [...students],

            getBadgeColor(status) {
                switch(status) {
                    case 'Excellent': return 'bg-emerald-100 text-emerald-700';
                    case 'Good': return 'bg-green-100 text-green-700';
                    case 'Needs Attention': return 'bg-orange-100 text-orange-700';
                    case 'At Risk': return 'bg-red-100 text-red-700';
                    default: return 'bg-gray-100 text-gray-700';
                }
            },

            render(data) {
                const tbody = document.getElementById('studentTableBody');
                tbody.innerHTML = '';

                data.forEach(student => {
                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0";
                    tr.onclick = function() {
                        // If it's Maria, go to populated view, else just go to view (mock behavior)
                        router.navigateTo('student');
                        // In a real app, we'd pass the ID to load specific data
                        if(student.id !== 8) {
                            // Update header mock-up for demo purposes
                            document.getElementById('student-name').innerText = student.name;
                            document.getElementById('student-initials').innerText = student.name.split(' ').map(n=>n[0]).join('');
                            document.getElementById('student-email').innerText = student.name.toLowerCase().replace(' ', '.') + '@student.lesha.com';
                            document.getElementById('student-score').innerText = student.score + '%';
                        } else {
                            // Reset to Maria (Hardcoded data in HTML)
                            document.getElementById('student-name').innerText = "Maria Kamati";
                            document.getElementById('student-initials').innerText = "MK";
                            document.getElementById('student-email').innerText = "maria.kamati@student.lesha.com";
                            document.getElementById('student-score').innerText = "68%";
                        }
                    };

                    tr.innerHTML = `
                        <td class="p-4 font-medium text-lesha-navy">${student.name}</td>
                        <td class="p-4">
                            <div class="flex items-center gap-2">
                                <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
